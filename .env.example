# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it is in .gitignore.
# In Coolify: paste these into the Environment Variables panel per service.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string-at-least-50-chars
DEBUG=False
ALLOWED_HOSTS=portal.fixseen.com,www.portal.fixseen.com

# ── Database (Coolify PostgreSQL resource) ────────────────────────────────────
DATABASE_URL=postgres://fixseen:<password>@<host>:5432/fixseen_db

# ── Redis (Coolify Redis resource) ────────────────────────────────────────────
REDIS_URL=redis://:<password>@<host>:6379/0

# ── Media Storage (persistent Docker volume path) ─────────────────────────────
# Must match the volume mount point in Coolify (e.g. /app/media)
MEDIA_ROOT=/app/media

# ── Email (Hetzner SMTP — update with your actual credentials) ────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.fixseen.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=payslips@fixseen.com
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=FixSeen Portal <payslips@fixseen.com>

# ── Business Logic ────────────────────────────────────────────────────────────
# HR Master Key — used as the PDF owner password on every encrypted payslip.
# Anyone with this key can open any generated payslip.
# KEEP THIS SECRET. Rotate it only if you change your encryption workflow.
PDF_HR_MASTER_KEY=HR_Admin_Master_Key

# ── Sentry Error Tracking (optional — leave blank to disable) ─────────────────
SENTRY_DSN=

# ── Django Settings Module ────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
